/dts-v1/;

#include "ipq5018.dtsi"

/ {
	model = "TP-Link WTA301 v1";
	compatible = "tplink,wta301-v1", "qcom,ipq5018";
	aliases {
		serial0 = &blsp1_uart1;
		led-boot = &led_system;
		led-failsafe = &led_system;
		led-running = &led_system;
		led-upgrade = &led_system;
	};
	chosen { stdout-path = "serial0:115200n8"; };
	leds {
		compatible = "gpio-leds";
		system {
			label = "blue:system"; gpios = <&tlmm 31 GPIO_ACTIVE_HIGH>;
		};
	};
	keys {
		compatible = "gpio-keys";
		reset { label = "reset"; gpios = <&tlmm 25 GPIO_ACTIVE_LOW>; linux,code = <KEY_RESTART>; };
		wps { label = "wps"; gpios = <&tlmm 24 GPIO_ACTIVE_LOW>; linux,code = <KEY_WPS_BUTTON>; };
	};
};
&tlmm {
	mdio_pins: mdio-pins {
		mdc { pins = "gpio36"; function = "mdc"; drive-strength = <8>; bias-pull-up; };
		mdio { pins = "gpio37"; function = "mdio"; drive-strength = <8>; bias-pull-up; };
	};
};
&blsp1_uart1 { status = "okay"; };
&qpic_bam { status = "okay"; };
&qpic_nand {
	status = "okay";
	nand@0 {
		reg = <0>; #address-cells = <1>; #size-cells = <1>;
		nand-ecc-strength = <4>; nand-ecc-step-size = <512>; nand-bus-width = <8>;
		partitions { compatible = "qcom,smem-part"; };
	};
};
&wifi0 { status = "okay"; qcom,ath11k-fw-memory-mode = <1>; qcom,ath11k-calibration-variant = "TP-Link_WTA301-v1"; };
&wifi1 { status = "okay"; qcom,ath11k-fw-memory-mode = <1>; qcom,ath11k-calibration-variant = "TP-Link_WTA301-v1"; };
